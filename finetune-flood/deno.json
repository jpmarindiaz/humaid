{
  "tasks": {
    "fetch": "deno run -A --env-file=.env src/generate.ts",
    "label:manifest": "deno run -A src/label_agents.ts",
    "label:anthropic": "deno run -A --env-file=.env src/label_anthropic.ts",
    "build": "deno run -A src/build_dataset.ts",
    "preview": "deno run -A src/preview.ts",
    "upload": "deno run -A src/upload_to_modal.ts",
    "pull": "deno run -A src/pull_checkpoints.ts",
    "package": "deno run -A src/package.ts",
    "serve": "deno run -A src/serve.ts",
    "eval": "deno run -A --env-file=.env src/evaluate.ts",
    "eval:compare": "deno run -A src/eval_compare.ts"
  },
  "imports": {
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.40.1",
    "@std/cli": "jsr:@std/cli@^1.0.6",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.5"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": false,
    "singleQuote": true
  }
}
