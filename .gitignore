# Sensitive
.env
.env.local
.env.*.local
*.pem
*.key

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
.firecrawl/

# Node / Deno
node_modules/

# Per-project derived data (each subproject also has its own .gitignore).
# We DO commit the labeled satellite tiles (data/raw, data/images), the
# leap-finetune JSONLs (~100KB), and the eval reports (evals/) so the repo
# is self-contained for browsing and for reproducing eval runs without
# re-fetching from SimSat. The fine-tuned weights and GGUFs live only on
# HuggingFace Hub (jpmarindiaz/lfm2-flood) — they're too big for GitHub
# (model.safetensors is 860MB, GGUFs 180-245MB, DeepSpeed shards 5GB+).
finetune-flood/outputs/

# Cloned third-party simulator — users clone upstream themselves; see simsat/README.md.
# Everything inside simsat/ except its README.md is ignored.
simsat/*
!simsat/README.md

# Cloned Liquid AI fine-tune library — users clone upstream themselves.
# Mostly venv (~1.2 GB) and vendor source. Same pattern as simsat/.
# humaid's own fine-tune config lives in finetune-flood/configs/flood_modal.yaml.
leap-finetune/

# Regenerable PDF-extraction cache from ds_to_markdown / Kreuzberg.
.kreuzberg/
